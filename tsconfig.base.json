{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "typeRoots": [
      "${configDir}/node_modules/@types",
      "${configDir}/../node_modules/@types",
      "${configDir}/../../node_modules/@types",
      "${configDir}/../../../node_modules/@types"
    ]
  }
}