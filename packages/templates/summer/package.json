{
  "name": "@docmd/template-summer",
  "version": "0.8.7",
  "description": "Summer template for docmd 0.8.7+",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && node scripts/copy-assets.mjs",
    "clean": "rm -rf dist"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@docmd/api": "workspace:*",
    "@types/node": "^25.9.2",
    "esbuild": "^0.28.0",
    "typescript": "^5.9.3"
  },
  "docmd": {
    "kind": "template",
    "displayName": "Summer",
    "tagline": "A bright, hopeful, summer-feel layout with a top search bar.",
    "preview": "assets/css/summer.css"
  },
  "keywords": [
    "docmd",
    "docmd-template",
    "template",
    "summer",
    "documentation",
    "theme"
  ],
  "engines": {
    "node": ">=18"
  },
  "author": {
    "name": "Ghazi",
    "url": "https://mgks.dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/docmd-io/docmd",
    "directory": "packages/templates/summer"
  },
  "bugs": {
    "url": "https://github.com/docmd-io/docmd/issues"
  },
  "homepage": "https://docmd.io",
  "funding": {
    "github": "https://github.com/sponsors/mgks"
  },
  "license": "MIT"
}
